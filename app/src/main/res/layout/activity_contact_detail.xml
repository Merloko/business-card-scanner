<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/textPersonName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/textCompanyName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginTop="4dp" />
                    <TextView
                        android:id="@+id/textJobTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout android:id="@+id/rowPhone"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="8dp" android:visibility="gone">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="📞" android:textSize="16sp"
                            android:importantForAccessibility="no"/>
                        <TextView android:id="@+id/textPhone"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="16sp" android:textColor="?attr/colorPrimary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/rowMobile"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="8dp" android:visibility="gone">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="📱" android:textSize="16sp"
                            android:importantForAccessibility="no"/>
                        <TextView android:id="@+id/textMobile"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="16sp" android:textColor="?attr/colorPrimary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/rowEmail"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="8dp" android:visibility="gone">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="✉" android:textSize="16sp"
                            android:importantForAccessibility="no"/>
                        <TextView android:id="@+id/textEmail"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="16sp" android:textColor="?attr/colorPrimary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/rowWebsite"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="8dp" android:visibility="gone">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="🌐" android:textSize="16sp"
                            android:importantForAccessibility="no"/>
                        <TextView android:id="@+id/textWebsite"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="16sp" android:textColor="?attr/colorPrimary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/rowAddress"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="8dp" android:visibility="gone">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="📍" android:textSize="16sp"
                            android:importantForAccessibility="no"/>
                        <TextView android:id="@+id/textAddress"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="16sp" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/rowNotes"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="8dp" android:visibility="gone">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="📝" android:textSize="16sp"
                            android:importantForAccessibility="no"/>
                        <TextView android:id="@+id/textNotes"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="16sp" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/rowTags"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="8dp" android:visibility="gone">
                        <TextView
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/label_tags"
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:layout_marginBottom="4dp"/>
                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupDetailTags"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <Button
                    android:id="@+id/btnSetReminder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/action_set_reminder"
                    app:icon="@drawable/ic_alarm"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                <Button
                    android:id="@+id/btnRecordMeeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/btn_record_meeting"
                    app:icon="@drawable/ic_mic"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>

            <LinearLayout android:id="@+id/cardFrontContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="12dp"
                android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/front_image" android:textStyle="bold" android:padding="4dp"/>
                <ImageView android:id="@+id/imageFront"
                    android:layout_width="match_parent" android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:clickable="true" android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:contentDescription="@string/front_image_tap"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cardBackContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="12dp"
                android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/back_image" android:textStyle="bold" android:padding="4dp"/>
                <ImageView android:id="@+id/imageBack"
                    android:layout_width="match_parent" android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:clickable="true" android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:contentDescription="@string/back_image_tap"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/rawOcrSection"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/raw_ocr_text" android:textStyle="bold" android:padding="4dp"/>
                <TextView android:id="@+id/textRawOcr"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="8dp" android:textSize="11sp" android:fontFamily="monospace"
                    android:background="@color/ocr_background"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_interactions"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                        <Button
                            android:id="@+id/btnAddInteraction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_add_interaction"
                            style="@style/Widget.MaterialComponents.Button.TextButton" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/logContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/textNoInteractions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_interactions"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
