<?xml version="1.0" encoding="utf-8"?>
<!-- Used by Android 12+ for cloud backup and device-to-device transfer -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="business_card_database" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="business_card_database" />
    </device-transfer>
</data-extraction-rules>
